# Copy to server/.env and fill in. See README → Configuration for details.

# --- required ---------------------------------------------------------------

# Postgres connection string. Local default below works after `npm run setup`.
DATABASE_URL=postgres://postgres@localhost:5432/playlog

# Cloudflare R2 (S3-compatible object storage for video bytes).
# Create a bucket + R2 user API token at https://dash.cloudflare.com → R2.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=playlog-videos
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# JWT signing secret for app auth. Use a long random string.
# Generate one: `openssl rand -base64 32`
JWT_SECRET=replace-me-with-a-long-random-string

# --- recommended ------------------------------------------------------------

# Public R2 hostname (r2.dev subdomain or custom domain). Strongly recommended:
# TwelveLabs sometimes rejects presigned URLs, but accepts public ones.
# R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# --- optional / for the AI pipeline -----------------------------------------

# TwelveLabs (video understanding). The /api/twelvelabs/* and coach analysis
# endpoints will fail without this. The rest of the app (auth, sessions,
# uploads, in-browser pose scoring) works without it.
# TWELVELABS_API_KEY=

# Anthropic (coaching feedback). The /api/coach/* endpoints will fail without
# this; the rest of the app works without it.
# ANTHROPIC_API_KEY=

# Server config (defaults shown).
# PORT=8787
# CORS_ORIGIN=http://localhost:8080
